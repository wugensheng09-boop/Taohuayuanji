{
  "name": "taohuayuan-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Immersive lesson desktop app for Textbook World Traverser.",
  "author": "Local Build",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "upstream:dev": "node upstream-server/src/server.mjs",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:prepare": "node scripts/prepare-desktop-build.mjs",
    "desktop:dist": "node scripts/desktop-dist.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.taohuayuan.desktop",
    "productName": "课本世界穿越器",
    "directories": {
      "output": "release",
      "buildResources": "src/app"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "!src/**/*",
      "!public/**/*",
      "!data/**/*",
      "!.next/**/*",
      "!scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-desktop/app-runtime",
        "to": "app-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": false,
    "electronDist": "node_modules/electron/dist",
    "electronVersion": "37.2.6",
    "win": {
      "icon": "src/app/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "课本世界穿越器-Setup-${version}.${ext}"
    }
  }
}
