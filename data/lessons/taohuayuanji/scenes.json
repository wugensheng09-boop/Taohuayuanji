        "id": "village_l1",
        "speakerMode": "narrator",
        "lineType": "auto",
        "text": "老人孩子安然自得，村人闻讯皆来。",
        "autoNextMs": 1600,
        "voiceTrack": "scene"
      },
      {
        "id": "village_i1",
        "speakerMode": "npc",
        "npcId": "villager",
        "lineType": "auto",
        "text": "席间，族长放下酒盏，凝神问我今是何世。",
        "autoNextMs": 2600,
        "interactionMode": "npc2",
        "interactionKey": "chief_dialogue",
        "voiceTrack": "inner"
      },
      {
        "id": "village_i2",
        "speakerMode": "npc",
        "npcId": "fisherman",
        "lineType": "auto",
        "text": "乃不知有汉，无论魏晋。",
        "autoNextMs": 1800,
        "voiceTrack": "quote"
      },
