    "timeline": [
      {
        "id": "cave_l1",
        "speakerMode": "narrator",
        "lineType": "auto",
        "text": "桃林到了尽头，前方忽然现出一座山。",
        "autoNextMs": 1500,
        "voiceTrack": "scene"
      },
      {
        "id": "cave_i1",
        "speakerMode": "narrator",
        "lineType": "auto",
        "text": "山间像有一道小口，我把船慢慢靠过去。",
        "autoNextMs": 2600,
        "voiceTrack": "inner"
      },
      {
        "id": "cave_i2",
        "speakerMode": "narrator",
        "lineType": "auto",
        "text": "山有小口，仿佛若有光。",
        "autoNextMs": 1800,
        "voiceTrack": "quote"
      },
      {
        "id": "cave_l4",
        "speakerMode": "narrator",
        "lineType": "auto",
        "text": "初极狭，才通人。复行数十步，豁然开朗。",
        "autoNextMs": 2400,
        "voiceTrack": "quote"
      }
    ],
