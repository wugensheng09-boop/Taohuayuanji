      {
        "id": "forest_i1",
        "speakerMode": "narrator",
        "lineType": "auto",
        "text": "花色映满水面，我一时看得出了神。",
        "autoNextMs": 2600,
        "voiceTrack": "inner"
      },
      {
        "id": "forest_i2",
        "speakerMode": "narrator",
        "lineType": "auto",
        "text": "中无杂树，芳草鲜美，落英缤纷。",
